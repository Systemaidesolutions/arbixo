# Copy this file to .env and fill in real values. Never commit .env itself.

# Local Postgres (matches docker-compose.yml exactly — see DEPLOYMENT.md)
DATABASE_URL="postgresql://ejas:ejas_local_dev@localhost:5432/ejas_web"

# For a hosted database (Vercel Postgres, Neon, Supabase — see DEPLOYMENT.md),
# replace the line above with the connection string that provider gives you.

# Required — signs and verifies session tokens. Generate a real one with:
#   openssl rand -base64 32
AUTH_SECRET="replace-this-with-a-real-random-32-byte-secret"

# Global admin account, created by `npm run prisma:seed`. Change the
# password after first login if this is a real deployment.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# Optional — email delivery for registration verification codes via
# resend.com. Without these, verification codes are logged to the
# server console instead of emailed (fine for local development, not
# for anyone you actually want to self-register).
RESEND_API_KEY=""
EMAIL_FROM="Arbixo <onboarding@resend.dev>"
