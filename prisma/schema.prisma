// ============================================================
// ARbixo — Prisma schema
// Converted from the "Easy Journal Accounting System" desktop
// manual, restructured as a single flat ledger-entry table —
// the same pattern Business Central uses for G/L Entry: one
// row per debit/credit line, grouped by Document No., instead
// of a separate header + line split.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// Authentication — email/password with a verification code sent
// by email before first login. Sessions are stateless signed JWTs
// (see lib/auth.ts), not a DB-backed session table, specifically
// so the auth check in middleware.ts can run on the Edge runtime
// without a database round trip — Prisma doesn't run on Edge.
// ------------------------------------------------------------
enum UserRole {
  ADMIN
  USER
}

// Subscriber (USER role) accounts have a subtype that determines what
// they can do. Not applicable to ADMIN accounts (stays null).
//   MANAGER        — everything a User can do, plus edit/void and approve
//   USER           — encode and post transactions, generate BIR reports
//   REPORT_CREATOR — view transactions and generate BIR reports only (read-only)
enum SubscriberSubtype {
  MANAGER
  USER
  REPORT_CREATOR
}

// Single-row table (id = "singleton") holding uploaded brand images as data
// URLs. Served (decoded) via /api/branding/[slot]; set from the admin
// Branding page. Kept out of the app payload — only the image bytes are
// fetched, and only when actually shown.
model AppSettings {
  id              String   @id @default("singleton")
  backgroundImage String?
  loginImage      String?
  headerLogo      String?
  // GCash collection account for subscription payments (admin-set).
  gcashName       String?
  gcashNumber     String?
  gcashQrImage    String?  @db.Text // the admin's real GCash QR (base64 data URL)
  updatedAt       DateTime @updatedAt
}

// Business-Central-style dated subscription pricing. The "current" price is the
// one whose window covers today: effectiveFrom <= now and (effectiveTo is null
// or >= now). Adding a new price closes the previously open one (sets its
// effectiveTo), so history is preserved and status is derivable from dates.
model SubscriptionPrice {
  id            String    @id @default(cuid())
  name          String                        // e.g. "Price A"
  amount        Decimal   @db.Decimal(10, 2)  // monthly rate
  currency      String    @default("PHP")
  effectiveFrom DateTime
  effectiveTo   DateTime?                      // null = open-ended / current
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([effectiveFrom])
}

enum VoucherDiscountType {
  FIXED
  PERCENT
}

// Single-use discount codes redeemed on the subscription payment page. Codes are
// random + unique so they can't be guessed. A voucher is usable only while
// isActive and unredeemed (redeemedAt is null).
model Voucher {
  id              String              @id @default(cuid())
  code            String              @unique
  discountType    VoucherDiscountType @default(FIXED)
  discountValue   Decimal             @db.Decimal(10, 2) // amount, or percent when PERCENT
  isActive        Boolean             @default(true)
  redeemedAt      DateTime?
  redeemedByCompanyId String?
  batchId         String?                                // groups a batch generation
  note            String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([batchId])
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

// Audit log of subscription payments. Snapshots the price and voucher used so
// the record stays accurate even if those are edited later.
model SubscriptionPayment {
  id             String        @id @default(cuid())
  company        Company       @relation(fields: [companyId], references: [id])
  companyId      String
  priceName      String
  baseAmount     Decimal       @db.Decimal(10, 2)
  currency       String        @default("PHP")
  voucherCode    String?
  discountAmount Decimal       @db.Decimal(10, 2) @default(0)
  amountDue      Decimal       @db.Decimal(10, 2)
  gcashRef       String?
  status         PaymentStatus @default(PENDING)
  periodStart    DateTime?
  periodEnd      DateTime?     // the subscription end this payment sets when verified
  createdById    String?
  createdByEmail String?
  verifiedById   String?
  verifiedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId, createdAt])
  @@index([status])
}

// Admin-curated shortcuts shown on every subscriber's dashboard — e.g. the
// BIR site, an online tax calculator, SSS/PhilHealth. Platform-wide (not
// company-scoped); the logo is an optional base64 data URL.
model RelatedLink {
  id        String   @id @default(cuid())
  name      String
  url       String
  logoUrl   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  role                  UserRole  @default(USER)

  // Simple self-service profile: a display name and an optional profile
  // photo (stored as a base64 data URL, same approach as company logos).
  name                  String?
  photoUrl              String?   @db.Text

  // Only meaningful for subscriber (USER role) accounts; null for admins.
  // Determines transaction/approval permissions — see SubscriberSubtype.
  subscriberSubtype     SubscriberSubtype?

  isVerified            Boolean   @default(false)
  verificationCode      String?
  verificationExpiresAt DateTime?

  // An admin can disable an account (e.g. a lapsed subscriber) without
  // deleting it — disabled users keep all their data but can't log in,
  // and any still-valid session is rejected on the next page load.
  isDisabled            Boolean   @default(false)

  // Password reset — admin (or a future "forgot password" flow) issues a
  // single-use token emailed to the user; it verifies against this hash
  // and expires. Stored hashed so a leaked DB row can't be used to reset.
  resetTokenHash        String?
  resetTokenExpiresAt   DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // ADMIN users are Arbixo staff — platform-wide, no single company.
  // USER (subscriber) accounts belong to exactly one company. This is
  // the multi-tenant boundary: every company-scoped query in the app
  // resolves "which company" from this field via lib/currentUser.ts,
  // never from a global "the only company" lookup.
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?
}

// ------------------------------------------------------------
// 1.1 Setup Company  (manual section 1.1)
// ------------------------------------------------------------
model Company {
  id                   String   @id @default(cuid())
  tin                  String
  taxClassification    TaxClassification
  registeredName       String?
  taxpayerLastName     String?
  taxpayerFirstName    String?
  taxpayerMiddleName   String?
  tradeName            String
  businessAddress      String
  // Structured PH address (added alongside the free-text businessAddress,
  // which now holds the street/building line).
  barangay             String?
  city                 String?
  province             String?
  zipCode              String
  rdoCode              String
  periodType           PeriodType @default(CALENDAR)
  fiscalMonthEnd       Int?
  businessType         String?
  registrationType     RegistrationType
  lineOfBusiness       String?
  telNo                String?
  faxNo                String?
  authorizedRep        String?
  authorizedRepPosition String?

  // When off, no audit-trail entries are recorded for this company —
  // an admin control to cap log growth / database size.
  auditLogEnabled      Boolean  @default(true)

  // Company logo (image URL) — shown on the subscriber dashboard.
  logoUrl              String?

  // Key of the project auto-created in the ARbixo Core ticketing app when this
  // company was created (best-effort link; null if ticketing sync was off or
  // failed).
  ticketProjectKey     String?

  // Company-level sign-in control. When false, NO user of this company can
  // log in (admin action for unpaid/closed accounts). A lapsed
  // subscription alone does not set this — only an admin does.
  isActive             Boolean  @default(true)

  // Monthly subscription (admin-managed). Expiry shows a renew reminder
  // but never blocks access by itself.
  billingEmail               String?
  subscriptionStartedAt      DateTime?
  subscriptionEndsAt         DateTime?
  subscriptionReminderSentAt DateTime? // guards against duplicate reminder emails

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  locations     Location[]
  accounts      Account[]
  customers     Customer[]
  vendors       Vendor[]
  employees     Employee[]
  contacts      Contact[]
  ledgerEntries LedgerEntry[]
  auditLogs     AuditLog[]
  taxPostingSetup TaxPostingSetup?
  users         User[]
  numberSeries  NumberSeries[]
  importations  Importation[]
  subscriptionPayments SubscriptionPayment[]
  items          Item[]
  purchaseDocs   PurchaseDoc[]
  salesDocs      SalesDoc[]
  stockMovements StockMovement[]
}

// Importation record for the BIR Summary List of Importations (SLI). Kept as a
// standalone capture (not a general-ledger posting) — the SLI is built directly
// from these. The taxable/exempt base is dutiableValue + charges; VAT is 12% of
// the taxable base when not exempt.
model Importation {
  id                String   @id @default(cuid())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         String
  assessReleaseDate DateTime // Assessment / release date from customs
  sellerName        String   // Name of foreign seller
  importDate        DateTime // Date of importation
  countryOrigin     String
  dutiableValue     Decimal  @db.Decimal(18, 2)
  charges           Decimal  @db.Decimal(18, 2) @default(0) // all charges before release from customs custody
  isVatExempt       Boolean  @default(false)
  vatAmount         Decimal  @db.Decimal(18, 2) @default(0) // 12% of (dutiable + charges) when taxable
  orNo              String   // Official Receipt no. of the duty/VAT payment
  paymentDate       DateTime
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companyId, importDate])
}

// Per-company, per-master-data "No. Series" (à la Business Central). An admin
// sets a prefix (e.g. "CUST"); new records get prefix + a zero-padded running
// number (e.g. CUST0000001) that auto-increments. entityType is one of
// "customer" | "vendor" | "employee" | "contact".
model NumberSeries {
  id         String   @id @default(cuid())
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  entityType String
  prefix     String
  nextNumber Int      @default(1)
  padding    Int      @default(7)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, entityType])
}

// 3.4 Setup Location — branches. Reports stay consolidated by
// default; Location just tags where an entry originated.
model Location {
  id          String   @id @default(cuid())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  address     String?
  tin         String?
  machineIdNo String?
  branchClass String?
  // BIR 3- or 5-digit branch code (head office = 000). Used in the branch's
  // alphalist/RELIEF filenames; falls back to the branch/company TIN suffix.
  branchCode  String?
  isDefault   Boolean  @default(false)

  ledgerEntries LedgerEntry[]

  @@unique([companyId, name])
}

// ------------------------------------------------------------
// Tax Posting Setup — tells the posting engine which GL accounts
// to hit for Input VAT, Output VAT, and Withholding Tax Payable.
// The manual does this invisibly/hardcoded; we make it explicit
// and configurable, the same idea as BC's VAT Posting Setup /
// General Posting Setup. One row per company.
// ------------------------------------------------------------
model TaxPostingSetup {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id])
  companyId String  @unique

  inputVatAccount   Account? @relation("InputVatPostingAccount", fields: [inputVatAccountId], references: [id])
  inputVatAccountId String?

  outputVatAccount   Account? @relation("OutputVatPostingAccount", fields: [outputVatAccountId], references: [id])
  outputVatAccountId String?

  withholdingTaxPayableAccount   Account? @relation("WithholdingTaxPayablePostingAccount", fields: [withholdingTaxPayableAccountId], references: [id])
  withholdingTaxPayableAccountId String?

  // Distinct from the liability above: when a CUSTOMER withholds tax from
  // paying us (Cash Receipts / Sales), the withheld amount is an ASSET —
  // Creditable Withholding Tax at Source — that offsets our income tax
  // due later. It is not the same account as the liability we credit
  // when WE withhold from a vendor (Cash Disbursement / Purchases). The
  // manual's own Cash Receipts screenshot labels this column
  // "WITAX (DEBIT)" versus Cash Disbursement's "W/TAX (CREDIT)".
  creditableWithholdingTaxAccount   Account? @relation("CreditableWithholdingTaxPostingAccount", fields: [creditableWithholdingTaxAccountId], references: [id])
  creditableWithholdingTaxAccountId String?

  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------------
// 1.2 Chart of Accounts (manual section 1.2)
// Stage 1 target — see the note at the bottom of this file for
// the robustness upgrades planned on top of this base model.
// ------------------------------------------------------------
enum AccountClassification {
  CASH_IN_BANK
  CASH_ON_HAND
  ACCOUNTS_RECEIVABLE
  OTHER_CURRENT_ASSET
  INVENTORY
  FIXED_ASSET
  ACCUMULATED_DEPRECIATION
  OTHER_ASSET
  ACCOUNTS_PAYABLE
  OTHER_CURRENT_LIABILITY
  LONG_TERM_PAYABLE
  EQUITY_DOES_NOT_CLOSE
  EQUITY_GETS_CLOSED
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

// Heading = a non-postable grouping row that subtotals the posting accounts
// nested beneath it. Posting = a leaf you can actually post transactions to.
enum AccountType {
  HEADING
  POSTING
}

model Account {
  id             String                @id @default(cuid())
  company        Company               @relation(fields: [companyId], references: [id])
  companyId      String
  code           String
  title          String
  classification AccountClassification
  accountType    AccountType           @default(POSTING)
  // Explicit display order within a parent — the imported chart's row order,
  // which account codes alone don't always reproduce.
  sortOrder      Int                   @default(0)
  isActive       Boolean               @default(true)

  // Hierarchy — lets "Cash in Bank" be a parent of "Cash in Bank - BPI",
  // "Cash in Bank - EIB", etc. (the manual's per-bank sub-accounts).
  parent         Account?  @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  parentAccountId String?
  children        Account[] @relation("AccountHierarchy")

  // Explicit rather than derived from classification, because contra
  // accounts break the simple mapping — e.g. Accumulated Depreciation
  // is classified as an asset-side account but carries a CREDIT normal
  // balance.
  normalBalance      NormalBalance
  openingBalance      Decimal?  @db.Decimal(18, 2) @default(0)
  openingBalanceDate DateTime?

  ledgerEntries  LedgerEntry[]
  inputVatPostingFor         TaxPostingSetup[] @relation("InputVatPostingAccount")
  outputVatPostingFor        TaxPostingSetup[] @relation("OutputVatPostingAccount")
  withholdingTaxPostingFor   TaxPostingSetup[] @relation("WithholdingTaxPayablePostingAccount")
  creditableWithholdingTaxPostingFor TaxPostingSetup[] @relation("CreditableWithholdingTaxPostingAccount")

  @@unique([companyId, code])
  @@index([parentAccountId])
}

// ------------------------------------------------------------
// 1.3 Setup Agent — split BC-style into Customer / Vendor /
// Employee / Contact instead of the manual's single Agent table
// with an AgentType discriminator. Each gets its own code
// sequence (its own @@unique([companyId, code])), matching how
// BC keeps separate No. Series for Customer vs. Vendor vs.
// Employee.
//
// Mapping from the manual's AgentType values:
//   Customer-Private, Customer-Gov't → Customer (customerType)
//   Supplier, Government Agency      → Vendor   (vendorType)
//   Employee                         → Employee
//   Other Contact                    → Contact
// ------------------------------------------------------------
enum TaxClassification {
  INDIVIDUAL
  NON_INDIVIDUAL
}

enum RegistrationType {
  VAT
  NON_VAT
}

enum PeriodType {
  CALENDAR
  FISCAL
}

enum CustomerType {
  PRIVATE
  GOVERNMENT // triggers the multiple-withholding-tax flow in the manual
}

enum VendorType {
  SUPPLIER
  GOVERNMENT_AGENCY // e.g. BIR/SSS/PhilHealth/Pag-IBIG remittance payees
}

model Customer {
  id                String   @id @default(cuid())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         String
  code              String
  tin               String?
  taxClassification TaxClassification
  registeredName    String?
  lastName          String?
  firstName         String?
  middleName        String?
  tradeName         String
  customerType      CustomerType
  registrationType  RegistrationType
  authorizedRep     String?
  address           String?
  barangay          String?
  city              String?
  province          String?
  zipCode           String?
  telNo             String?
  faxNo             String?
  cellNo            String?
  email             String?
  website           String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@unique([companyId, code])
}

model Vendor {
  id                String   @id @default(cuid())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         String
  code              String
  tin               String?
  taxClassification TaxClassification
  registeredName    String?
  lastName          String?
  firstName         String?
  middleName        String?
  tradeName         String
  vendorType        VendorType
  registrationType  RegistrationType
  authorizedRep     String?
  address           String?
  barangay          String?
  city              String?
  province          String?
  zipCode           String?
  telNo             String?
  faxNo             String?
  cellNo            String?
  email             String?
  website           String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@unique([companyId, code])
}

model Employee {
  id         String   @id @default(cuid())
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  code       String
  tin        String?
  lastName   String
  firstName  String
  middleName String?
  position   String?
  address    String?
  barangay   String?
  city       String?
  province   String?
  zipCode    String?
  telNo      String?
  cellNo     String?
  email      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@unique([companyId, code])
}

// Catch-all for parties that are neither customer, vendor, nor employee
// but still show up on a transaction — e.g. a lender on a loan payable,
// an owner on an equity drawdown. Same role as BC's Contact table.
model Contact {
  id                String   @id @default(cuid())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         String
  code              String
  tin               String?
  taxClassification TaxClassification
  registeredName    String?
  lastName          String?
  firstName         String?
  middleName        String?
  tradeName         String
  registrationType  RegistrationType
  address           String?
  barangay          String?
  city              String?
  province          String?
  zipCode           String?
  telNo             String?
  cellNo            String?
  email             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@unique([companyId, code])
}

// ------------------------------------------------------------
// ATC (Alphanumeric Tax Code) reference table — deliberately NOT
// hardcoded into application logic. BIR revises these rates
// periodically (e.g. RR No. 5-2025 and RR No. 24-2025 both
// changed creditable withholding tax rates within the same
// year), so this is editable reference data, not a fixed enum.
// Seed data should be treated as a starting point and verified
// against the BIR's current Alphanumeric Tax Code table before
// relying on it: https://www.bir.gov.ph/WithHoldingTax
// ------------------------------------------------------------
enum IncomePaymentType {
  GOODS
  SERVICES
  BOTH
}

model AtcCode {
  id                String            @id @default(cuid())
  code              String            @unique // e.g. "WC160"
  description       String
  ratePercent       Decimal           @db.Decimal(5, 2) // e.g. 2.00 for 2%
  incomePaymentType IncomePaymentType @default(BOTH)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

// ------------------------------------------------------------
// The five journals/portals — now a single flat ledger table.
//
// Business Central parallel:
//   - journalType   ≈ Source Code   (which journal posted this)
//   - documentType  ≈ Document Type (Payment/Receipt/Invoice/...)
//   - documentNo    ≈ Document No.  (groups every line of one
//                                    transaction — e.g. all rows
//                                    of one CV, one Invoice)
//   - lineNo        ≈ Line No.      (order within the document)
//   - entryNo       ≈ Entry No.     (immutable ledger sequence)
// ------------------------------------------------------------
enum JournalType {
  CASH_DISBURSEMENT
  CASH_RECEIPT
  SALES_ON_ACCOUNT
  PURCHASE_ON_ACCOUNT
  GENERAL_JOURNAL
}

enum DocumentType {
  PAYMENT       // Cash Disbursement (CV)
  RECEIPT       // Cash Receipts (OR)
  INVOICE       // Sales on Account
  CREDIT_MEMO   // Sales/Purchase Return
  PURCHASE      // Purchase on Account (PV)
  JOURNAL       // General Journal (JV)
}

enum VatType {
  VAT_12
  ZERO_RATED
  VAT_EXEMPT
  NON_VAT
  IMPORTATION
}

enum TaxSource {
  GOODS
  SERVICE
  CAPITAL_GOODS
}

enum CounterpartyType {
  CUSTOMER
  VENDOR
  EMPLOYEE
  CONTACT
}

model LedgerEntry {
  id         String   @id @default(cuid())
  entryNo    Int      @default(autoincrement()) // permanent ledger sequence, never reused/edited

  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  journalType  JournalType
  documentType DocumentType?
  documentNo   String        // CV no. / OR no. / Invoice no. / PV no. / JV no. — groups related lines
  lineNo       Int           // display order within the document
  isReturn     Boolean       @default(false)
  postingDate  DateTime

  account   Account @relation(fields: [accountId], references: [id])
  accountId String

  // Exactly zero or one of these four should be set per entry — enforced
  // at the API layer (Prisma has no native "exactly one of" constraint).
  // counterpartyType mirrors whichever FK is populated, so reports can
  // filter/group without four separate null-checks.
  counterpartyType CounterpartyType?
  customer         Customer? @relation(fields: [customerId], references: [id])
  customerId       String?
  vendor           Vendor?   @relation(fields: [vendorId], references: [id])
  vendorId         String?
  employee         Employee? @relation(fields: [employeeId], references: [id])
  employeeId       String?
  contact          Contact?  @relation(fields: [contactId], references: [id])
  contactId        String?

  debitAmount  Decimal @db.Decimal(18, 2) @default(0)
  creditAmount Decimal @db.Decimal(18, 2) @default(0)

  description  String? // Particulars / Nature
  checkNo      String? // Cash Disbursement only
  isCancelled  Boolean @default(false)

  // Maker-checker review. A document posted by a subscriber "User" starts
  // unapproved (pending a Manager's review); one posted by a Manager is
  // auto-approved. This is an oversight stamp — it does NOT hide entries
  // from reports. Defaults to true so pre-existing entries stay approved.
  isApproved   Boolean   @default(true)
  approvedById String?
  approvedAt   DateTime?

  // --- VAT computation (VAT Computation popup in the manual) ---
  vatType     VatType?
  grossAmount Decimal? @db.Decimal(18, 2)
  netAmount   Decimal? @db.Decimal(18, 2)
  vatAmount   Decimal? @db.Decimal(18, 2) // Input Tax or Output Tax
  taxSource   TaxSource?

  // --- Withholding tax ---
  atcCode        String?
  atcDescription String?
  withholdingAmt Decimal? @db.Decimal(18, 2)

  // --- Importation / capital goods (manual 1.10) ---
  importSellerName    String?
  importAssessDate    DateTime?
  importDate          DateTime?
  importCountryOrigin String?
  importEntryNo       String?
  importDutiableValue Decimal? @db.Decimal(18, 2)
  importLandedCost    Decimal? @db.Decimal(18, 2)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One line number per document — mirrors how you'd never have
  // two "line 1"s under the same CV/Invoice/JV number.
  @@unique([companyId, journalType, documentNo, lineNo])
  @@index([companyId, journalType, postingDate])
  @@index([companyId, documentNo])
  @@index([accountId])
  @@index([customerId])
  @@index([vendorId])
  @@index([employeeId])
  @@index([contactId])
}

// ------------------------------------------------------------
// 4.1 Audit Trail
// ------------------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  // Optional: platform-level actions (e.g. an admin editing users) aren't
  // scoped to a single company.
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?
  username  String
  ipAddress String?
  action    String

  // Populated for automatic create/update/delete logging (see the Prisma
  // extension in lib/prisma.ts). Null for hand-written entries like logins.
  entityType String?
  entityId   String?
  operation  String? // CREATE | UPDATE | DELETE

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
}

// ============================================================
// Deferred for a later stage (not selected for this pass):
//   accountType (Posting vs. Heading/Total, non-postable subtotal
//   rows) and isDirectPostingAllowed. Revisit if you want subtotal
//   rows in the Chart of Accounts tree.
// ============================================================

// ============================================================
// Inventory + Purchase-on-Account document module (new).
// Perpetual inventory, MOVING WEIGHTED AVERAGE costing: each Item keeps a
// running quantityOnHand + avgCost, recomputed on every stock-in. Inventory
// items post their cost to the Inventory ASSET account (perpetual); non-inventory
// and service items post directly to an expense account. Account references are
// stored as plain IDs (validated in code) to avoid widening Account/Vendor with
// many back-relations.
// ============================================================
enum ItemType {
  INVENTORY // stock-tracked, valued as an asset
  NON_INVENTORY // consumable/expensed on purchase, qty optional
  SERVICE // no stock, expensed on purchase
}

enum PurchaseDocStatus {
  DRAFT
  FOR_APPROVAL
  APPROVED
  POSTED
  CANCELLED
}

enum StockMovementType {
  PURCHASE
  PURCHASE_RETURN
  SALE
  SALE_RETURN
  ADJUSTMENT
}

model Item {
  id          String   @id @default(cuid())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
  code        String
  description String
  type        ItemType @default(INVENTORY)
  uom         String? // unit of measure, e.g. "pcs", "ream"
  vatType     VatType  @default(VAT_12)
  defaultCost Decimal  @db.Decimal(18, 4) @default(0) // last/default purchase cost

  // Perpetual inventory running state (moving weighted average).
  quantityOnHand Decimal @db.Decimal(18, 4) @default(0)
  avgCost        Decimal @db.Decimal(18, 4) @default(0)

  // Posting accounts (plain IDs referencing Account).
  inventoryAccountId String? // Inventory asset (INVENTORY items)
  expenseAccountId   String? // COGS / expense (all types on issue or on purchase for non-inventory)
  incomeAccountId    String? // sales income (used later by the Sales document)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements StockMovement[]

  @@unique([companyId, code])
}

model PurchaseDoc {
  id         String            @id @default(cuid())
  company    Company           @relation(fields: [companyId], references: [id])
  companyId  String
  status     PurchaseDocStatus @default(DRAFT)

  transactionNo   String // POA-2026-000001
  transactionDate DateTime
  vendorId        String?
  supplierTin     String?
  locationId      String? // branch (Location)
  terms           String? // "30 Days"
  dueDate         DateTime?
  referenceNo     String? // supplier invoice no.
  purchaseOrderNo String?
  currency        String    @default("PHP")
  remarks         String?

  payableAccountId String? // AP account credited on post
  vatInclusive     Boolean @default(true)

  // Denormalized totals snapshot.
  totalBeforeVat Decimal @db.Decimal(18, 2) @default(0)
  discountAmount Decimal @db.Decimal(18, 2) @default(0)
  otherCharges   Decimal @db.Decimal(18, 2) @default(0)
  totalVat       Decimal @db.Decimal(18, 2) @default(0)
  totalAmount    Decimal @db.Decimal(18, 2) @default(0)

  // Posting link — the ledger documentNo used when POSTED (= transactionNo).
  postedAt    DateTime?
  createdById String?
  postedById  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines PurchaseDocLine[]

  @@unique([companyId, transactionNo])
  @@index([companyId, status])
}

model PurchaseDocLine {
  id     String      @id @default(cuid())
  doc    PurchaseDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  docId  String
  lineNo Int

  itemId      String? // Item reference (null for a free-text/memo line)
  itemCode    String? // snapshot
  description String
  quantity    Decimal @db.Decimal(18, 4) @default(1)
  uom         String?
  unitCost    Decimal @db.Decimal(18, 4) @default(0)
  discountPercent Decimal @db.Decimal(9, 4) @default(0)
  vatType     VatType @default(VAT_12)

  // Computed line figures (net + VAT).
  amount    Decimal @db.Decimal(18, 2) @default(0) // net, before VAT
  vatAmount Decimal @db.Decimal(18, 2) @default(0)
  accountId String? // inventory or expense account this line posts to

  @@index([docId])
}

model StockMovement {
  id           String            @id @default(cuid())
  company      Company           @relation(fields: [companyId], references: [id])
  companyId    String
  item         Item              @relation(fields: [itemId], references: [id])
  itemId       String
  type         StockMovementType
  movementDate DateTime

  quantity  Decimal @db.Decimal(18, 4) // signed: + in, - out
  unitCost  Decimal @db.Decimal(18, 4)
  totalCost Decimal @db.Decimal(18, 2)

  // Running balances AFTER this movement (moving weighted average).
  balanceQty     Decimal @db.Decimal(18, 4)
  balanceAvgCost Decimal @db.Decimal(18, 4)

  sourceType String? // e.g. "PURCHASE_DOC"
  sourceId   String? // PurchaseDoc id
  createdAt  DateTime @default(now())

  @@index([companyId, itemId, movementDate])
}

// ============================================================
// Sales document (Sales Order) — mirror of PurchaseDoc. Sells items to a
// customer: posts revenue (Dr A/R, Cr Sales income + Output VAT) and, for
// INVENTORY items, cost of goods sold at the item's moving-average cost
// (Dr COGS, Cr Inventory) plus a negative StockMovement. Reuses PurchaseDocStatus.
// ============================================================
model SalesDoc {
  id         String            @id @default(cuid())
  company    Company           @relation(fields: [companyId], references: [id])
  companyId  String
  status     PurchaseDocStatus @default(DRAFT)

  transactionNo   String // SO-2026-000001
  transactionDate DateTime
  customerId      String?
  customerTin     String?
  locationId      String?
  terms           String?
  dueDate         DateTime?
  referenceNo     String? // customer PO / reference
  currency        String    @default("PHP")
  remarks         String?

  receivableAccountId String? // A/R account debited on post
  vatInclusive        Boolean @default(true)

  totalBeforeVat Decimal @db.Decimal(18, 2) @default(0)
  discountAmount Decimal @db.Decimal(18, 2) @default(0)
  otherCharges   Decimal @db.Decimal(18, 2) @default(0)
  totalVat       Decimal @db.Decimal(18, 2) @default(0)
  totalAmount    Decimal @db.Decimal(18, 2) @default(0)

  postedAt    DateTime?
  createdById String?
  postedById  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines SalesDocLine[]

  @@unique([companyId, transactionNo])
  @@index([companyId, status])
}

model SalesDocLine {
  id     String   @id @default(cuid())
  doc    SalesDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  docId  String
  lineNo Int

  itemId          String?
  itemCode        String?
  description     String
  quantity        Decimal @db.Decimal(18, 4) @default(1)
  uom             String?
  unitPrice       Decimal @db.Decimal(18, 4) @default(0)
  discountPercent Decimal @db.Decimal(9, 4) @default(0)
  vatType         VatType @default(VAT_12)

  amount    Decimal @db.Decimal(18, 2) @default(0) // net, before VAT
  vatAmount Decimal @db.Decimal(18, 2) @default(0)
  accountId String? // income account this line posts to

  @@index([docId])
}
